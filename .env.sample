# MCP server secrets — copy this file to .env and fill in real values.
# .env is gitignored; this file is safe to commit.
#
# IMPORTANT: Keep this strictly for MCP-specific secrets.
# Do NOT set PATH, HOME, or other system variables here.

# ── dbt MCP server ───────────────────────────────────────────────
# Absolute path to your dbt project directory
DBT_PROJECT_DIR=/path/to/dbt/project
# Absolute path to the dbt binary (run: which dbt)
DBT_PATH=/path/to/.local/bin/dbt

# ── Redshift MCP server ──────────────────────────────────────────
DB_NAME="Add from Secrets"
HOST="Add from Secrets"
RW_ETL_USER_NAME="Add from Secrets"
RW_ETL_USER_PASSWORD="Add from Secrets"
DB_PORT=5439
# AWS profile and region for Redshift access
AWS_ACCOUNT_ID=
AWS_PROFILE=
AWS_REGION=
# Acceptable values: dev, prod
# ENV=dev
DEV_INITIALS=

# ── Langfuse MCP server ──────────────────────────────────────────
# Base64-encoded "public_key:secret_key" — get from https://us.cloud.langfuse.com/
LANGFUSE_BASE_64_TOKEN=

# ── Contentful MCP server ────────────────────────────────────────
# Note: SPACE_ID and ENVIRONMENT_ID are generic names — verify they don't conflict with other tools in your environment.
CONTENTFUL_MANAGEMENT_ACCESS_TOKEN=
SPACE_ID=
ENVIRONMENT_ID=
CONTENTFUL_HOST=


# ── Datadog MCP server ──────────────────────────────────────────
DD_API_KEY=
DD_APPLICATION_KEY=
