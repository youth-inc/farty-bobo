{
  "mcpServers": {
    "linear": {
      "command": "/bin/bash",
      "args": ["-c", "~/.claude/scripts/linear-mcp.sh"]
    },
    "contentful": {
      "command": "/bin/bash",
      "args": ["-c", "~/.claude/scripts/contentful-mcp.sh"]
    },
    "datadog": {
      "command": "/bin/bash",
      "args": ["-c", "~/.claude/scripts/datadog-mcp.sh"]
    },
    "posthog": {
      "command": "/bin/bash",
      "args": ["-c", "~/.claude/scripts/posthog-mcp.sh"]
    },
    "honeybadger": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "HONEYBADGER_PERSONAL_AUTH_TOKEN",
        "ghcr.io/honeybadger-io/honeybadger-mcp-server"
      ],
      "env": {
        "HONEYBADGER_PERSONAL_AUTH_TOKEN": "${HONEYBADGER_PERSONAL_AUTH_TOKEN}"
      }
    }
  }
}
