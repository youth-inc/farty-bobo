{
  "mcpServers": {
    "linear": {
      "command": "/bin/bash",
      "args": ["-c", "~/.claude/scripts/linear-mcp.sh"]
    },
    "dbt": {
      "command": "/bin/bash",
      "args": ["-c", "~/.claude/scripts/dbt-mcp.sh"]
    },
    "awslabs.redshift-mcp-server": {
      "command": "/bin/bash",
      "args": ["-c", "~/.claude/scripts/redshift-mcp.sh"]
    },
    "contentful": {
      "command": "/bin/bash",
      "args": ["-c", "~/.claude/scripts/contentful-mcp.sh"]
    },
    "datadog": {
      "command": "/bin/bash",
      "args": ["-c", "~/.claude/scripts/datadog-mcp.sh"]
    },
    "posthog": {
      "command": "/bin/bash",
      "args": ["-c", "~/.claude/scripts/posthog-mcp.sh"]
    },
    "yaz": {
      "command": "/bin/bash",
      "args": ["-c", "~/.claude/scripts/yaz-mcp.sh"]
    }
  },
  "preferences": {
    "quickEntryShortcut": "off",
    "quickEntryDictationShortcut": "off",
    "coworkScheduledTasksEnabled": true,
    "ccdScheduledTasksEnabled": true,
    "sidebarMode": "chat",
    "coworkWebSearchEnabled": true
  }
}
