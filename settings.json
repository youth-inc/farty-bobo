{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(uv run:*)",
      "Bash(find:*)",
      "Bash(git fetch:*)",
      "Bash(git checkout:*)",
      "Bash(git pull:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(gh pr create:*)",
      "Bash(nvm:*)",
      "Bash(git log:*)",
      "Bash(git reset:*)",
      "Bash(git worktree:*)",
      "Bash(git -C:*)",
      "Bash(git symbolic-ref:*)",
      "Bash(git config --get:*)",
      "Bash(git rev-parse:*)",
      "Bash(cat:*)",
      "WebSearch",
      "Bash(sort:*)",
      "Bash(grep:*)",
      "Bash(python3:*)",
      "Bash(npm run test:*)",
      "Bash(npm run test:static:*)",
      "Bash(npx tsc:*)",
      "Bash(npx eslint:*)",
      "Bash(ls:*)",
      "Bash(npx vitest:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm test:*)",
      "Bash(ln:*)",
      "Bash(test:*)",
      "Bash(gh gist create:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/node_modules/**)",
      "Read(node_modules/**)",
      "Read(**/.venv/**)",
      "Read(**/.env/**)"
    ],
    "defaultMode": "auto"
  },
  "model": "opusplan",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/post-edit-check.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/pre-tool-check.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/refresh-links.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/commands/statusline-command.sh"
  },
  "enabledPlugins": {
    "evals-skills@hamelsmu-evals-skills": true,
    "code-review@claude-plugins-official": true,
    "deploy-on-aws@agent-plugins-for-aws": true,
    "codex@openai-codex": true,
    "frontend-design@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "farty-bobo@farty-bobo": false
  },
  "extraKnownMarketplaces": {
    "hamelsmu-evals-skills": {
      "source": {
        "source": "github",
        "repo": "hamelsmu/evals-skills"
      }
    },
    "agent-plugins-for-aws": {
      "source": {
        "source": "github",
        "repo": "awslabs/agent-plugins"
      }
    },
    "farty-bobo": {
      "source": {
        "source": "github",
        "repo": "fartybobo/farty-bobo"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "vladikk-modularity": {
      "source": {
        "source": "github",
        "repo": "vladikk/modularity"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": false
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "low",
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "skills": {
    "langfuse": {
      "type": "command",
      "command": "npx langfuse-cli@latest get-skill"
    }
  },
  "feedbackSurveyState": {
    "lastShownTime": 1754572875128
  },
  "knownMarketplaces": []
}
